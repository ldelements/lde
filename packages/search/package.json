{
  "name": "@lde/search",
  "version": "0.8.1",
  "description": "Engine- and domain-agnostic core for RDF-backed search: a unified declarative field model (SearchField/SearchType/SearchSchema), a neutral query IR, the SearchEngine port with logical result types, and a streaming CONSTRUCT-to-document projection. Bakes in no engine, protocol, or domain.",
  "repository": {
    "url": "git+https://github.com/ldelements/lde.git",
    "directory": "packages/search"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "development": "./src/adapter.ts",
      "default": "./dist/adapter.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "development": "./src/testing.ts",
      "default": "./dist/testing.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@lde/text-normalization": "^0.1.1",
    "@rdfjs/types": "^2.0.1",
    "inflection": "^3.0.2",
    "jsonld": "^9.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@tpluscode/rdf-ns-builders": "^5.0.0",
    "@types/jsonld": "^1.5.15",
    "n3": "^2.1.1"
  },
  "peerDependencies": {
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
